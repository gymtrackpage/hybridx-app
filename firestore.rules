rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Fields the client is never allowed to change via update.
    // These must only be set via Admin SDK (server-side).
    // NOTE: trialStartDate / trialEndDate are included — the trial window is
    // derived from trialStartDate, so allowing client updates would let a user
    // extend their own trial indefinitely.
    function isWritingProtectedUserField() {
      let protected = ['isAdmin', 'subscriptionStatus', 'subscriptionTier',
                       'stripeCustomerId', 'stripeSubscriptionId', 'subscriptionId',
                       'trialEndsAt', 'trialEndDate', 'trialStartDate'];
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(protected);
    }

    // On create the client stamps trialStartDate (at signup) but must not
    // self-grant admin or a paid/active subscription. trialStartDate is pinned
    // to server time (±10m) so the trial cannot be future-dated.
    function isValidUserCreate() {
      let data = request.resource.data;
      return (!('isAdmin' in data) || data.isAdmin == false)
          && (!('subscriptionStatus' in data) || data.subscriptionStatus == 'trial')
          && (!('subscriptionTier' in data))
          && (!('stripeCustomerId' in data) || data.stripeCustomerId == null)
          && (!('subscriptionId' in data) || data.subscriptionId == null)
          && (!('trialEndsAt' in data))
          && (!('trialEndDate' in data))
          && (!('trialStartDate' in data) || (
               data.trialStartDate >= request.time - duration.value(10, 'm')
               && data.trialStartDate <= request.time + duration.value(10, 'm')
             ));
    }

    match /users/{userId} {
      // Users can only read and update their own document,
      // and must not touch protected server-managed fields.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !isWritingProtectedUserField();

      // On create, the document path must match the authenticated user's UID,
      // and the client may not self-grant admin/subscription privileges.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && isValidUserCreate();

      // Allow access to subcollections like personalPrograms
      match /personalPrograms/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /programs/{programId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /workoutSessions/{sessionId} {
      // For read operations, check userId on the existing document
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;

      // For write operations, check userId on the incoming document
      allow create, update, delete: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Client may create notifications addressed to itself
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Client may mark its own notifications as read (update only the `read` field)
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /journalEntries/{entryId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create, update: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /analyticsEvents/{eventId} {
      // Authenticated users can write events tagged with their own UID
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Unauthenticated visitors can write anonymous events (e.g. signup page view before account exists)
      allow create: if request.resource.data.userId == 'anonymous';
      // No client reads, updates, or deletes — admin SDK only
    }
  }
}
